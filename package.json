{
	"name": "@liiift-studio/vf-clamp",
	"version": "2.1.3",
	"description": "Restrict a variable font's axis ranges to a specific subfamily scope — like CSS clamp() for design space.",
	"type": "module",
	"main": "dist/index.cjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"test": "vitest",
		"test:run": "vitest run",
		"lint": "tsc --noEmit",
		"sync-plugin-views": "bash scripts/sync-plugin-views.sh",
		"sync-plugin-views:check": "bash scripts/sync-plugin-views.sh --dry-run",
		"prepublishOnly": "npm run test:run && npm run build"
	},
	"dependencies": {
		"@web-alchemy/fonttools": "^1.4.0"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.0.0",
		"vite-plugin-dts": "^4.0.0",
		"vitest": "^3.0.0",
		"next": "16.2.2"
	},
	"keywords": [
		"variable-font",
		"font",
		"typography",
		"typeface",
		"vf-clamp",
		"fonttools",
		"instancer",
		"named-instances",
		"axis",
		"design-space",
		"pyodide",
		"wasm",
		"woff2",
		"ttf",
		"opentype"
	],
	"author": "Quinn Keaveney <quinn@liiift.studio>",
	"license": "MIT",
	"homepage": "https://vfclamp.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/Liiift-Studio/vf-clamp.git"
	},
	"bugs": {
		"url": "https://github.com/Liiift-Studio/vf-clamp/issues"
	},
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	}
}
