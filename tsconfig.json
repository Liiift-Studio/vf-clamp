{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "site"]
}
